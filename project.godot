; Engine configuration file.
; Keep this scaffold gameplay-free until the design board and asset ledger are complete.

config_version=5

[application]

config/name="APK 2D RPG"
config/description="Portrait-first 2D RPG scaffold for Android and Web targets."
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.7", "GL Compatibility")
config/icon=""

[display]

window/size/viewport_width=1080
window/size/viewport_height=1920
window/size/window_width_override=540
window/size/window_height_override=960
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation=1

[input]

move_left={
"deadzone": 0.5,
"events": []
}
move_right={
"deadzone": 0.5,
"events": []
}
move_up={
"deadzone": 0.5,
"events": []
}
move_down={
"deadzone": 0.5,
"events": []
}
interact={
"deadzone": 0.5,
"events": []
}
attack={
"deadzone": 0.5,
"events": []
}
dodge={
"deadzone": 0.5,
"events": []
}
skill_1={
"deadzone": 0.5,
"events": []
}
skill_2={
"deadzone": 0.5,
"events": []
}
skill_3={
"deadzone": 0.5,
"events": []
}
open_menu={
"deadzone": 0.5,
"events": []
}
open_map={
"deadzone": 0.5,
"events": []
}

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/canvas_textures/default_texture_filter=0
